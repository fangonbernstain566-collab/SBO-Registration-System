NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never prefix with NEXT_PUBLIC_. From Supabase Project Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: comma-separated allowlist of admin emails. Leave blank to allow
# any authenticated Supabase user (fine if you only ever create admin users).
ADMIN_EMAILS=
